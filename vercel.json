{
  "version": 2,
  "name": "roden-web",
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.otf",  "use": "@vercel/static" },
    { "src": "Fotos de proyectos/**", "use": "@vercel/static" },
    { "src": "Fotos Inspiración/**",  "use": "@vercel/static" },
    { "src": "Foto personal/**",      "use": "@vercel/static" },
    { "src": "Fotos taller/**",       "use": "@vercel/static" },
    { "src": "Renders/**",            "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/",      "dest": "/prototipo.html" },
    { "src": "/admin", "dest": "/admin.html"     }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.+\\.otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
